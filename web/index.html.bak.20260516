<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>主网自动化竞赛 · 训练中心</title>
<style>
/* ===== 色系定义 ===== */
:root {
  --bg: #0f172a;
  --card: #1e293b;
  --card-hover: #334155;
  --border: #1e293b;
  --border-light: #334155;
  --text: #e2e8f0;
  --text-muted: #94a3b8;
  --text-dim: #64748b;
  --subj-os: #10b981;
  --subj-os-dark: #047857;
  --subj-platform: #0ea5e9;
  --subj-platform-dark: #0369a1;
  --subj-db: #8b5cf6;
  --subj-db-dark: #6d28d9;
  --subj-net: #f97316;
  --subj-net-dark: #c2410c;
  --subj-stable: #eab308;
  --subj-stable-dark: #ca8a04;
  --subj-alert: #ef4444;
  --subj-alert-dark: #b91c1c;
  --success: #10b981;
  --warning: #f97316;
  --danger: #ef4444;
  --info: #0ea5e9;
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.16);
  --shadow: 0 4px 12px rgba(0, 0, 0, 0.24);
}

body.light {
  --bg: #f8fafc;
  --card: #ffffff;
  --card-hover: #f1f5f9;
  --border: #e2e8f0;
  --border-light: #cbd5e1;
  --text: #1e293b;
  --text-muted: #64748b;
  --text-dim: #94a3b8;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  padding: 24px 16px;
  min-height: 100vh;
  transition: background 0.2s, color 0.2s;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
}

h1 {
  font-size: 26px;
  font-weight: 700;
  margin-bottom: 4px;
  letter-spacing: -0.5px;
}

h2 {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}

p {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 4px;
}

button {
  padding: 8px 14px;
  background: var(--success);
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-family: inherit;
  letter-spacing: 0.3px;
}

button:hover:not(:disabled) {
  background: var(--subj-os-dark);
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
}

button:active:not(:disabled) {
  transform: translateY(0);
}

button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

button.s {
  background: var(--text-dim);
}

button.s:hover:not(:disabled) {
  background: var(--text-muted);
}

button.warn {
  background: var(--warning);
}

button.warn:hover:not(:disabled) {
  background: var(--subj-net-dark);
}

button.red {
  background: var(--danger);
}

button.red:hover:not(:disabled) {
  background: var(--subj-alert-dark);
}

input, select, textarea {
  width: 100%;
  padding: 8px 12px;
  background: var(--border);
  color: var(--text);
  border: 1px solid var(--border-light);
  border-radius: 6px;
  font-size: 13px;
  font-family: inherit;
  transition: border 0.2s;
}

input:focus, select:focus, textarea:focus {
  outline: none;
  border-color: var(--success);
  box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.1);
}

.theme-toggle {
  position: fixed;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  padding: 0;
  font-size: 16px;
  background: var(--card);
  color: var(--text);
  border: 1px solid var(--border-light);
  cursor: pointer;
  z-index: 50;
  transition: all 0.2s;
}

.theme-toggle:hover {
  transform: scale(1.1);
  box-shadow: var(--shadow-sm);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 20px;
  background: var(--card);
  border: 1px solid var(--border-light);
  border-radius: 8px;
  padding: 16px 20px;
  margin-bottom: 24px;
  box-shadow: var(--shadow-sm);
  flex-wrap: wrap;
}

.topbar-item {
  display: flex;
  align-items: baseline;
  gap: 6px;
  font-size: 13px;
}

.topbar-label {
  color: var(--text-muted);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.topbar-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}

.topbar-sub {
  color: var(--text-muted);
  font-size: 12px;
}

.subjects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
  margin-bottom: 28px;
}

.subject-card {
  background: var(--card);
  border: 1px solid var(--border-light);
  border-radius: 8px;
  padding: 16px;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.subject-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: var(--subj-color);
  transition: width 0.3s ease-out;
}

.subject-card:hover {
  border-color: var(--subj-color);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
  background: var(--card-hover);
}

.subject-card:hover::before {
  width: 8px;
}

.subject-card.os { --subj-color: var(--subj-os); }
.subject-card.platform { --subj-color: var(--subj-platform); }
.subject-card.db { --subj-color: var(--subj-db); }
.subject-card.net { --subj-color: var(--subj-net); }
.subject-card.stable { --subj-color: var(--subj-stable); }
.subject-card.alert { --subj-color: var(--subj-alert); }

.subject-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}

.subject-dot {
  display: inline-block;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--subj-color);
  flex-shrink: 0;
}

.subject-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}

.subject-big {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6px;
  margin: 16px 0 14px;
  font-variant-numeric: tabular-nums;
  letter-spacing: -1px;
}

.big-num {
  font-size: 44px;
  font-weight: 700;
  color: var(--subj-color);
  line-height: 1;
}

.big-sep {
  font-size: 26px;
  font-weight: 300;
  color: var(--text-dim);
}

.big-total {
  font-size: 26px;
  font-weight: 500;
  color: var(--text-muted);
}

.subject-meta {
  display: flex;
  gap: 12px;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.subject-meta-item {
  display: flex;
  align-items: center;
  gap: 4px;
  font-variant-numeric: tabular-nums;
}

.meta-num {
  color: var(--text);
  font-weight: 600;
  font-size: 13px;
}

.error-num {
  color: var(--danger);
  font-weight: 600;
  font-size: 13px;
}

.progress-bar {
  width: 100%;
  height: 5px;
  background: var(--border-light);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 8px;
}

.progress-fill {
  height: 100%;
  background: var(--subj-color);
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.progress-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.progress-pct {
  color: var(--text);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.recent-item {
  font-size: 12px;
  color: var(--text-muted);
  padding: 8px 0;
  border-top: 1px solid var(--border-light);
  margin-bottom: 10px;
}

.recent-label {
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin-bottom: 4px;
  display: block;
  font-weight: 500;
}

.recent-time {
  color: var(--text-dim);
  font-size: 11px;
}

.subject-actions {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.subject-actions button {
  flex: 1;
  padding: 8px 12px;
  font-size: 12px;
  border-radius: 6px;
  background: var(--border-light);
  color: var(--text);
  transition: all 0.2s;
}

.subject-actions button:hover:not(:disabled) {
  background: var(--subj-color);
  color: white;
  transform: translateY(-1px);
}

.subject-actions button.primary {
  background: var(--subj-color);
  color: white;
  font-weight: 600;
}

.subject-actions button.primary:hover:not(:disabled) {
  background: var(--text);
  filter: brightness(0.9);
}

.footer-actions {
  display: flex;
  gap: 10px;
  justify-content: center;
  padding-top: 20px;
  border-top: 1px solid var(--border-light);
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.footer-actions button {
  padding: 10px 16px;
  background: var(--border-light);
  color: var(--text);
}

.footer-actions button:hover:not(:disabled) {
  background: var(--text-muted);
  color: white;
}

.settings-panel {
  background: var(--card);
  border: 1px solid var(--border-light);
  border-radius: 8px;
  margin-top: 16px;
  overflow: hidden;
}

.settings-toggle {
  width: 100%;
  padding: 12px 16px;
  background: transparent;
  color: var(--text);
  border: none;
  text-align: left;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-bottom: 1px solid var(--border-light);
}

.settings-toggle:hover {
  background: var(--card-hover);
}

.settings-toggle .toggle-icon {
  display: inline-block;
  transition: transform 0.3s;
}

.settings-toggle.open .toggle-icon {
  transform: rotate(90deg);
}

.settings-content {
  padding: 16px;
  display: none;
}

.settings-content.open {
  display: block;
  animation: slideDown 0.2s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.setting-row {
  margin-bottom: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.setting-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

#loadingOverlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.92);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(2px);
}

#loadingOverlay.show {
  display: flex;
}

#loadingOverlay .box {
  background: var(--card);
  padding: 32px;
  border-radius: 12px;
  min-width: 340px;
  max-width: 540px;
  border: 1px solid var(--border-light);
  animation: popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

#loadingOverlay h3 {
  color: var(--success);
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
  text-align: center;
}

.spinner {
  display: inline-block;
  width: 28px;
  height: 28px;
  border: 3px solid var(--border-light);
  border-top-color: var(--success);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.progress-bar-large {
  width: 100%;
  height: 6px;
  background: var(--border-light);
  border-radius: 3px;
  overflow: hidden;
  margin: 12px 0 8px;
}

.progress-fill-large {
  height: 100%;
  background: var(--success);
  transition: width 0.3s;
}

#loadingDetail {
  font-size: 12px;
  color: var(--text-muted);
  max-height: 200px;
  overflow-y: auto;
  margin-top: 12px;
  padding: 8px;
  background: var(--bg);
  border-radius: 6px;
  line-height: 1.6;
}

#loadingDetail div {
  margin: 4px 0;
}

footer {
  text-align: center;
  font-size: 11px;
  color: var(--text-dim);
  padding-top: 24px;
  margin-top: 32px;
  border-top: 1px solid var(--border-light);
}

footer a {
  color: var(--success);
  text-decoration: none;
}

footer a:hover {
  text-decoration: underline;
}

@media (max-width: 768px) {
  .subjects-grid {
    grid-template-columns: 1fr;
  }
  .topbar {
    gap: 12px;
    padding: 12px 14px;
  }
  h1 {
    font-size: 22px;
  }
  .theme-toggle {
    width: 32px;
    height: 32px;
    font-size: 14px;
  }
}
</style>
</head>
<body>
<button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" title="切换主题">🌙</button>

<div class="container">
  <div style="margin-bottom: 24px;">
    <h1>📚 主网竞赛 · 训练中心</h1>
    <p>按学科答题 → API 批卷 → 错点提示 → 内嵌盲敲。完整一站式闭环。</p>
  </div>

  <div class="subjects-grid" id="subjectsGrid">
  </div>

  <div class="footer-actions">
    <button onclick="location.href='notes.html'" class="s">📷 速记本</button>
    <button onclick="toggleSettings()" class="s">⚙️ 设置</button>
  </div>

  <div class="settings-panel">
    <button class="settings-toggle" onclick="toggleSettingsPanel(this)">
      <span class="toggle-icon">▶</span>
      <span>🔧 高级设置</span>
    </button>
    <div class="settings-content">
      <div class="setting-row">
        <label class="setting-label">AIHUBMIX API Key</label>
        <input type="password" id="apiKey" placeholder="sk-...">
      </div>

      <div class="setting-row">
        <label class="setting-label">变式题数量</label>
        <select id="drillN">
          <option value="5">5 道 (快测)</option>
          <option value="10" selected>10 道 (推荐)</option>
          <option value="20">20 道 (集中刷)</option>
          <option value="-1">全部错题 (慎用，可能费 token)</option>
        </select>
      </div>

      <div class="setting-row">
        <label class="setting-label">批卷模型</label>
        <select id="model">
          <option value="gpt-4o-mini" selected>gpt-4o-mini (默认 · 快/便宜)</option>
          <option value="gpt-4o">gpt-4o (更准)</option>
        </select>
      </div>

      <div class="setting-row">
        <label class="setting-label">手动加载 JSON</label>
        <textarea id="jsonInput" placeholder='{"subject":"操作系统","questions":[...]}'></textarea>
        <div style="display: flex; gap: 8px; margin-top: 8px;">
          <button class="s" onclick="loadDemoJSON()" style="flex: 1;">示例</button>
          <button onclick="startFromCustomJSON()" style="flex: 1;">开始盲敲</button>
        </div>
      </div>
    </div>
  </div>

  <footer>
    GitHub: <a href="https://github.com/aerfagogogo/zhuwang-type-drill">aerfagogogo/zhuwang-type-drill</a>
    · UI v2.0 Vibe Island
  </footer>
</div>

<div id="loadingOverlay">
  <div class="box">
    <div style="text-align: center;">
      <div class="spinner"></div>
      <h3 id="loadingTitle">正在生成变式题…</h3>
    </div>
    <div class="progress-bar-large"><div class="progress-fill-large" id="progFill" style="width: 0%"></div></div>
    <div style="text-align: center; font-size: 12px; color: var(--text-muted); margin-bottom: 12px;" id="loadingSub">0 / 0</div>
    <div id="loadingDetail"></div>
    <button class="red" style="width: 100%; margin-top: 16px;" onclick="abortDrill()">中止</button>
  </div>
</div>

<script>
const $ = id => document.getElementById(id);
const STATE_KEY = 'trainerState_v2';
const HIST_KEY = 'trainerHistory_v2';

let DATA = {};
let abortFlag = false;

const SUBJ_COLORS = {
  '操作系统': 'os',
  '系统平台': 'platform',
  '数据库': 'db',
  '网络分析': 'net',
  '稳态监控': 'stable',
  '综合智能告警': 'alert',
};

async function init() {
  $('apiKey').value = localStorage.getItem('apiKey') || '';
  $('model').value = localStorage.getItem('model') || 'gpt-4o-mini';

  $('apiKey').addEventListener('change', () => localStorage.setItem('apiKey', $('apiKey').value.trim()));
  $('model').addEventListener('change', () => localStorage.setItem('model', $('model').value));

  try {
    const r = await fetch('exam_data.json?_t=' + Date.now());
    DATA = await r.json();
  } catch (e) {
    console.error('题库加载失败', e);
  }

  renderSubjects();

  const enc = new URLSearchParams(location.search).get('q');
  if (enc) {
    try {
      const j = decodeURIComponent(escape(atob(enc)));
      $('jsonInput').value = j;
      if (!confirm('检测到 ?q= 旧链接，要载入吗？')) return;
      startFromCustomJSON();
    } catch (e) {
      alert('URL 参数错: ' + e.message);
    }
  }
}

function renderSubjects() {
  const grid = $('subjectsGrid');
  grid.innerHTML = '';

  for (const [subj, questions] of Object.entries(DATA)) {
    const total = questions.length;
    const practiced = countPracticed(subj);
    const pct = total > 0 ? Math.round((practiced / total) * 100) : 0;
    const colorClass = SUBJ_COLORS[subj] || 'os';

    const card = document.createElement('div');
    card.className = `subject-card ${colorClass}`;
    card.innerHTML = `
      <div class="subject-header">
        <div class="subject-dot"></div>
        <div class="subject-name">${escapeHtml(subj)}</div>
      </div>

      <div class="subject-big">
        <span class="big-num">${practiced}</span>
        <span class="big-sep">/</span>
        <span class="big-total">${total}</span>
      </div>

      <div class="progress-bar">
        <div class="progress-fill" style="width: ${pct}%"></div>
      </div>

      <div class="subject-actions">
        <button class="primary" onclick="gotoExam('${escapeHtml(subj).replace(/'/g, "\\'")}')">→ 进试卷</button>
        <button onclick="startDrill('${escapeHtml(subj).replace(/'/g, "\\'")}')">✦ 特训</button>
      </div>
    `;

    grid.appendChild(card);
  }
}

function countPracticed(subj) {
  const ids = new Set();
  let state = {};
  try { state = JSON.parse(localStorage.getItem(STATE_KEY)) || {}; } catch (e) {}
  let hist = [];
  try { hist = JSON.parse(localStorage.getItem(HIST_KEY)) || []; } catch (e) {}

  if (state[subj] && state[subj].entries) {
    for (const e of state[subj].entries) {
      if (e && e.phase === 'completed' && e.id) ids.add(e.id);
    }
  }
  for (const h of hist) {
    if (h && h.subject === subj && h.entries) {
      for (const e of h.entries) {
        if (e && e.phase === 'completed' && e.id) ids.add(e.id);
      }
    }
  }
  return ids.size;
}

function gotoExam(subj) {
  if (!subj) {
    alert('请选学科');
    return;
  }
  localStorage.setItem('lastSubj', subj);
  location.href = 'exam.html?subj=' + encodeURIComponent(subj);
}

function collectWrongs() {
  const result = {};
  let state = {};
  try {
    state = JSON.parse(localStorage.getItem(STATE_KEY)) || {};
  } catch (e) {}
  let hist = [];
  try {
    hist = JSON.parse(localStorage.getItem(HIST_KEY)) || [];
  } catch (e) {}

  const allSessions = [];
  for (const subj in state) {
    if (state[subj] && state[subj].entries) {
      allSessions.push({ subject: subj, entries: state[subj].entries });
    }
  }
  for (const h of hist) {
    if (h && h.subject && h.entries) {
      allSessions.push({ subject: h.subject, entries: h.entries });
    }
  }

  const map = {};
  for (const sess of allSessions) {
    if (!map[sess.subject]) map[sess.subject] = {};
    for (const e of sess.entries) {
      const isWrong =
        (e.verdict === 'wrong' || e.verdict === 'partial' || e.verdict === 'dontknow') ||
        e.mark === 'dontknow';
      if (!isWrong) continue;
      const prev = map[sess.subject][e.id];
      if (!prev || (e.ts || 0) >= (prev.ts || 0)) map[sess.subject][e.id] = e;
    }
  }

  for (const subj in map) {
    result[subj] = Object.values(map[subj]);
  }
  return result;
}

function escapeHtml(c) {
  return String(c).replace(/[<>&"']/g, ch => ({
    '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;'
  }[ch]));
}

async function startDrill(subject) {
  const key = $('apiKey').value.trim();
  if (!key) {
    alert('请先填 AIHUBMIX Key');
    return;
  }
  if (!DATA[subject]) {
    alert('该学科题库未加载');
    return;
  }

  const allWrongs = collectWrongs()[subject] || [];
  if (!allWrongs.length) {
    alert('该学科还没有错题');
    return;
  }

  let n = parseInt($('drillN').value, 10);
  if (n === -1 || n > allWrongs.length) n = allWrongs.length;
  const samples = allWrongs.slice(-n);

  const idMap = {};
  for (const q of DATA[subject]) idMap[q.id] = q;
  const tasks = samples.filter(e => idMap[e.id]).map(e => ({
    src: idMap[e.id],
    wrong: e
  }));

  if (!tasks.length) {
    alert('错题的原题在题库里找不到（可能题库改了 id）');
    return;
  }

  abortFlag = false;
  $('loadingOverlay').classList.add('show');
  $('loadingTitle').textContent = '正在生成变式题…';
  $('loadingDetail').textContent = '';
  $('progFill').style.width = '0%';
  $('loadingSub').textContent = '0 / ' + tasks.length;

  const generated = [];
  const model = $('model').value;
  for (let i = 0; i < tasks.length; i++) {
    if (abortFlag) {
      $('loadingOverlay').classList.remove('show');
      return;
    }
    const t = tasks[i];
    $('loadingSub').textContent = (i + 1) + ' / ' + tasks.length + ' （' + t.src.id + '）';
    try {
      const v = await genVariant(key, model, t.src, t.wrong);
      generated.push({
        id: '变式-' + t.src.id + '-' + Date.now().toString(36),
        title: '变式 · ' + t.src.title,
        题面: v.题面,
        标答: v.标答,
        题源: '变式题（原：' + t.src.id + '）',
        _origin_id: t.src.id,
      });
      $('loadingDetail').innerHTML += '<div>✅ ' + escapeHtml(t.src.id) + ' → ' + escapeHtml((v.题面 || '').slice(0, 40)) + '…</div>';
    } catch (err) {
      $('loadingDetail').innerHTML += '<div style="color: #ef4444">❌ ' + escapeHtml(t.src.id) + ': ' + escapeHtml(err.message.slice(0, 80)) + '</div>';
    }
    $('progFill').style.width = ((i + 1) / tasks.length * 100) + '%';
    $('loadingDetail').scrollTop = $('loadingDetail').scrollHeight;
  }

  if (!generated.length) {
    alert('一道变式题都没生成成功，可能 API 故障。\n请检查 Key 是否正确。');
    $('loadingOverlay').classList.remove('show');
    return;
  }

  sessionStorage.setItem('drillData', JSON.stringify({
    subject: subject,
    drillMode: true,
    ts: Date.now(),
    questions: generated,
  }));

  $('loadingTitle').textContent = '✅ 生成完成，进入特训…';
  setTimeout(() => {
    location.href = 'exam.html?mode=drill';
  }, 600);
}

function abortDrill() {
  abortFlag = true;
}

async function genVariant(key, model, src, wrong) {
  const wp = (wrong.wrong_points || []).slice(0, 5).join('\n- ');
  const prompt = '你是 Linux/凝思系统实操题命题人。基于下面这道用户曾做错的原题，生成一道"测试同一知识点但换条件"的变式题。\n\n' +
    '原题：\n' + (src.题面 || '').slice(0, 500) + '\n\n' +
    '原标答：\n' + (src.标答 || '').slice(0, 800) + '\n\n' +
    (wp ? '用户当时的错处：\n- ' + wp + '\n\n' : '') +
    '变式要求：\n1. 测试同一个核心知识点 / 同一类命令\n2. 至少换 2-3 处条件\n3. 难度与原题相当\n4. 给出完整的题面和标答\n5. 标答保留代码块\n\n严格返回 JSON，无 markdown：\n{"题面":"...","标答":"..."}';

  const res = await fetch('https://aihubmix.com/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Authorization': 'Bearer ' + key,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      model: model,
      messages: [{ role: 'user', content: prompt }],
      temperature: 0.7,
      max_tokens: 1200
    }),
  });
  if (!res.ok) throw new Error('API ' + res.status);
  const data = await res.json();
  let c = data.choices[0].message.content.trim();
  c = c.replace(/^```(?:json)?\s*/, '').replace(/```\s*$/, '').trim();
  return JSON.parse(c);
}

function loadDemoJSON() {
  $('jsonInput').value = JSON.stringify({
    subject: '示例',
    questions: [{
      id: '示例-001',
      题面: '每分钟记录内存到文件',
      drills: ['crontab -e', '* * * * * free >> /home/d5000/zhejiang/Desktop/zhangsan.txt']
    }]
  }, null, 2);
}

function startFromCustomJSON() {
  try {
    const d = JSON.parse($('jsonInput').value);
    if (!d.questions || !d.questions.length) {
      alert('JSON 里没题');
      return;
    }
    sessionStorage.setItem('drillData', JSON.stringify({
      subject: d.subject || '自定义',
      drillMode: true,
      questions: d.questions.map(q => ({
        id: q.id,
        title: q.id,
        题面: q.题面 || '',
        标答: (q.drills || []).join('\n'),
        题源: '自定义 JSON',
      }))
    }));
    location.href = 'exam.html?mode=drill';
  } catch (e) {
    alert('JSON 解析失败: ' + e.message);
  }
}

function toggleSettingsPanel(btn) {
  btn.classList.toggle('open');
  const content = btn.nextElementSibling;
  content.classList.toggle('open');
}

function toggleSettings() {
  const toggle = document.querySelector('.settings-toggle');
  if (toggle) {
    toggleSettingsPanel(toggle);
  }
}

function applyTheme(t) {
  if (t === 'light') {
    document.body.classList.add('light');
    $('themeBtn').textContent = '☀️';
  } else {
    document.body.classList.remove('light');
    $('themeBtn').textContent = '🌙';
  }
}

function toggleTheme() {
  const next = document.body.classList.contains('light') ? 'dark' : 'light';
  applyTheme(next);
  localStorage.setItem('theme', next);
}

applyTheme(localStorage.getItem('theme') || 'dark');

init();
</script>
</body>
</html>
